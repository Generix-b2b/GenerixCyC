<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified" attributeFormDefault="unqualified">

    <xs:element name="InvoiceGNX" type="InvoiceGNXType"/>

    <xs:complexType name="InvoiceGNXType">
        <xs:sequence>
            <xs:element name="FileHeader" type="FileHeaderType"/>
            <xs:element name="Invoices" type="InvoicesType"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="InvoicesType">
        <xs:sequence>
            <xs:element name="InvoiceWrapper" type="InvoiceWrapperType" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Conjunto de datos de una factura, incluyendo las partes y el detalle del documento.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="FileHeaderType">
        <xs:sequence>
            <xs:element name="SchemaVersion" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Versión del esquema utilizada para generar el documento.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Modality" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Modalidad del envío.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoiceIssuerType" type="InvoiceIssuerTypeEnum">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Tipo de emisor de la factura</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Batch" type="BatchType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Lote</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="BatchType">
        <xs:sequence>
            <xs:element name="BatchIdentifier" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Identificador único del lote de facturas.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoicesCount" type="xs:integer">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Número de facturas incluidas en el lote.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TotalInvoicesAmount" type="AmountContainerType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Total facturas del lote.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TotalOutstandingAmount" type="AmountContainerType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Total del lote a pago.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TotalExecutableAmount" type="AmountContainerType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Total del lote a Ejecutar.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoiceCurrencyCode" type="CurrencyCodeType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Moneda del lote, según la Norma ISO 4217. Valor por defecto: EUR.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="AmountContainerType">
        <xs:sequence>
            <xs:element name="TotalAmount" type="xs:decimal">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Importe total expresado en la moneda de la factura.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="EquivalentInEuros" type="xs:decimal" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Importe equivalente expresado en euros.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:simpleType name="CurrencyCodeType">
        <xs:restriction base="xs:string">
            <xs:length value="3"/>
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="CountryCodeType">
        <xs:restriction base="xs:string">
            <xs:length value="2"/>
        </xs:restriction>
    </xs:simpleType>

    <xs:complexType name="InvoiceWrapperType">
        <xs:sequence>
            <xs:element name="Parties" type="PartiesType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Datos de las partes que intervienen en la factura.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Legislacion" type="LegislacionType" minOccurs="0"/>
            <xs:element name="Invoice" type="InvoiceType" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Datos del documento de factura.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="PartiesType">
        <xs:sequence>
            <xs:element name="SellerParty" type="PartyType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BG-4 | Grupo de términos de negocio que proporcionan información sobre el vendedor.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="BuyerParty" type="PartyType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BG-7 | Un conjunto de términos de negocio que ofrecen información sobre el comprador.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ThirdParty" type="PartyType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BG-ES-3 | Un conjunto de términos de negocio que ofrecen información relativa a un tercero.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="PartyType">
        <xs:sequence>
            <xs:element name="TaxIdentification" type="TaxIdentificationType"/>
            <xs:element name="PartyIdentification" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-30 / BT-47 / Identificación adicional de la parte.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="LegalEntity" type="LegalEntityType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Grupo de términos de negocio con la información jurídica y de contacto de la parte.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="TaxIdentificationType">
        <xs:sequence>
            <xs:element name="PersonTypeCode" type="PersonTypeCodeEnum">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Tipo de persona.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ResidenceTypeCode" type="ResidenceTypeCodeEnum">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Tipo de residencia a efectos fiscales.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TaxIdentificationNumber" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-32 / BT-48 / BT-ES-12 | Número de identificación fiscal (NIF/NIE) de la parte.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="LegalEntityType">
        <xs:sequence>
            <xs:element name="CorporateName" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-27 / BT-44 | Nombre y apellidos o razón social de la parte.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TradeName" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Nombre comercial de la parte.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="RegistrationData" type="RegistrationDataType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Datos registrales: Inscripcion Registro, Tomo, Folio...</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Address" type="AddressType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BG-5 / BG-8 | Grupo de términos de negocio que proporciona información de la dirección postal de la parte.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ContactDetails" type="ContactDetailsType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BG-6 / BG-9 | Grupo de términos de negocio que ofrecen información de contacto de la parte.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="RegistrationDataType">
        <xs:sequence>
            <xs:element name="Book" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Libro de inscripción en el Registro Mercantil.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="RegisterOfCompaniesLocation" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Localidad del Registro Mercantil.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Sheet" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Hoja de inscripción en el Registro Mercantil.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Folio" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Folio de inscripción en el Registro Mercantil.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Section" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Sección de inscripción en el Registro Mercantil.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Volume" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Tomo de inscripción en el Registro Mercantil.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="AdditionalRegistrationData" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Datos registrales adicionales.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="AddressType">
        <xs:sequence>
            <xs:element name="Address" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-35 / BT-50 | Se consignará la dirección postal de la parte.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="AdditionalAddress" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Información adicional de la dirección postal de la parte.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="PostCode" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-38 / BT-53 | Se consignará el código postal de la parte.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Town" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-37 / BT-52 | Se consignará la localidad de la parte.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Province" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-39 / BT-54 | Se consignará la provincia de la parte.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="CountryCode" type="CountryCodeType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-40 / BT-55 | Se consignará el código del país de la parte. En la Norma EN ISO 3166-1</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="ContactDetailsType">
        <xs:sequence>
            <xs:element name="Telephone" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-42 / BT-57 | Número de teléfono de contacto de la parte.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Telephone2" type="xs:string" minOccurs="0"/>
            <xs:element name="WebAddress" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Dirección del sitio web de contacto.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ElectronicMail" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-43 / BT-58 | Dirección de correo electrónico de contacto de la parte.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="LastName" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Apellidos de la parte.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="FirstName" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-41 / BT-56 | Nombre de la parte.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="LegislacionType">
        <xs:sequence>
            <xs:any minOccurs="0" maxOccurs="unbounded" processContents="lax"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="InvoiceType">
        <xs:sequence>
            <xs:element name="InvoiceHeader" type="InvoiceHeaderType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Grupo de términos de negocio con los datos de cabecera de la factura.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoiceIssueData" type="InvoiceIssueDataType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Grupo de términos de negocio con los datos de expedición de la factura.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TaxesOutputs" type="TaxSectionType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BG-23 | Grupo de términos de negocio que proporcionan información sobre el desglose del IVA en diferentes categorías.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TaxesWithheld" type="TaxSectionType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BG-ES-4 | Grupo de términos de negocio que proporcionan información relativa a las retenciones practicadas en la factura.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoiceTotals" type="InvoiceTotalsType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BG-22 | Grupo de términos de negocio que proporcionan los totales monetarios de la factura.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Items" type="InvoiceLineListType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Datos de una línea individual de la factura.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="PaymentDetails" type="PaymentDetailsType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BG-16 | Un grupo de términos de negocio que ofrecen información acerca del pago.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="LegalLiterals" type="LegalLiteralsType" minOccurs="0"/>
            <xs:element name="AdditionalData" type="AdditionalDataType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Grupo de términos de negocio con datos adicionales de la factura.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="InvoiceHeaderType">
        <xs:sequence>
            <xs:element name="InvoiceNumber" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-1 | Número y serie que identifican la factura emitida.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoiceDocumentType" type="InvoiceDocumentTypeEnum">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-3 | Tipo de factura.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoiceClass" type="InvoiceClassEnum">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-ES-1 | Valor que indica la originalidad de la factura.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoiceDescription" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Descripción general del contenido de la factura.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="PreviousInvoiceNumber" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Número de la factura anterior, cuando proceda.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Corrective" type="CorrectiveType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BG-ES-1 | Este grupo recoge los datos relativos al tipo de factura rectificativa y/o modalidad.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="CorrectiveType">
        <xs:sequence>
            <xs:element name="InvoiceNumber" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-25 | Número y serie que identifican la factura emitida referenciada o sustituida.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ReasonCode" type="ReasonCodeEnum">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-ES-2 | Indicador del motivo de la rectificación.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ReasonDescription" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Descripción del motivo de la rectificación.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoiceIssueDate" type="DateTimeType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-26 | Fecha de expedición de la factura referenciada o sustituida.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="CorrectionMethod" type="CorrectionMethodEnum">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-ES-3 | Código que especifica la modalidad de rectificación empleada.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="CorrectionMethodDescription" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Descripción de la modalidad de rectificación empleada.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="CorrectiveAmounts" type="CorrectiveAmountsType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BG-ES-2 | Este grupo recoge los importes rectificados, en los casos en los que se proceda.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="CorrectiveAmountsType">
        <xs:sequence>
            <xs:element name="GrossAmount" type="xs:decimal">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-ES-4 | Base imponible de la factura rectificada.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TaxAmount" type="xs:decimal">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-ES-5 | Cuota repercutida de la factura rectificada.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ChargeAmount" type="xs:decimal">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-ES-6 | Cuota recargo de equivalencia de la factura rectificada.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="InvoiceIssueDataType">
        <xs:sequence>
            <xs:element name="IssueDate" type="DateTimeType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-2 | Fecha en la que se ha expedido la factura.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="PreviousInvoiceDate" type="DateTimeType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Fecha de expedición de la factura anterior, cuando proceda.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoicingPeriod" type="PeriodType" minOccurs="0"/>
            <xs:element name="InvoiceCurrencyCode" type="CurrencyCodeType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-5 | Moneda en la que se expresan todos los importes de la factura, usando los códigos de la Norma ISO-4217.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TaxCurrencyCode" type="CurrencyCodeType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-6 | Moneda en la que se expresan todas las tasas de la factura, usando los códigos de la Norma ISO-4217</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="LanguageName" type="LanguageCodeType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Idioma en que se expresa la factura, según la Norma ISO 639-1.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="PeriodType">
        <xs:sequence>
            <xs:element name="StartDate" type="DateTimeType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Fecha de inicio del periodo de facturación.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="EndDate" type="DateTimeType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Fecha de fin del periodo de facturación.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="TaxSectionType">
        <xs:sequence>
            <xs:element name="Tax" type="TaxType" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="TaxType">
        <xs:sequence>
            <xs:element name="TaxTypeCode" type="TaxTypeCodeEnum">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-118 / BT-151 | Identificación de la categoría de IVA correspondiente a la cuota tributaria.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TaxRegimeCode" type="TaxRegimeCodeEnum">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-161 | Se consignará la clave de régimen correspondiente a la operación.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TaxOperationType" type="TaxOperationTypeEnum" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Tipo de operación a efectos del impuesto.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TaxExemptionReasonCode" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-120 / BT-121 | Texto exento o razón exención.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TaxRate" type="xs:decimal">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-119 / BT-152 | Tipo de Impuesto, representado en forma de porcentaje.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TaxableBase" type="AmountContainerType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-116 | Suma de todas las bases imponibles a las que se les aplica la misma categoría de impuesto.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TaxAmount" type="AmountContainerType">
                <xs:annotation>
                    <xs:documentation xml:lang="en">BT-117 | La cuota de impuesto por categoría.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="InvoiceTotalsType">
        <xs:sequence>
            <xs:element name="GeneralDiscounts" type="GeneralDiscountsType" minOccurs="0">
                <xs:annotation>
