                    <xs:documentation xml:lang="sp">Firma electrónica asociada al registro de facturación.</xs:documentation>
                    <xs:documentation xml:lang="en">Electronic signature associated with the billing record.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="PlaceholderOthers" type="xs:string" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>

