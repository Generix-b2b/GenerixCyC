    <xs:complexType name="QRAttachmentType">
        <xs:sequence>
            <xs:element name="URL" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-ES-47 | Se debe consignar la URL correspondiente al QR VERI*FACTU o el que corresponda según normativa aplicable.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-ES-47 | The URL corresponding to the VERI*FACTU QR or as applicable according to current regulations.</xs:documentation>
