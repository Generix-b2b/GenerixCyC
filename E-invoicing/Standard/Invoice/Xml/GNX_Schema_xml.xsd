<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified" attributeFormDefault="unqualified">

    <xs:element name="InvoiceGNX" type="InvoiceGNXType"/>

    <xs:complexType name="InvoiceGNXType">
        <xs:sequence>
            <xs:element name="FileHeader" type="FileHeaderType"/>
            <xs:element name="Invoices" type="InvoicesType"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="InvoicesType">
        <xs:sequence>
            <xs:element name="InvoiceWrapper" type="InvoiceWrapperType" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Conjunto de datos de una factura, incluyendo las partes y el detalle del documento.</xs:documentation>
                    <xs:documentation xml:lang="en">Dataset for a single invoice, including parties and document details.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="FileHeaderType">
        <xs:sequence>
            <xs:element name="SchemaVersion" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Versión del esquema utilizada para generar el documento.</xs:documentation>
                    <xs:documentation xml:lang="en">Version of the schema used to generate the document.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Modality" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Modalidad del envío.</xs:documentation>
                    <xs:documentation xml:lang="en">Submission modality.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoiceIssuerType" type="InvoiceIssuerTypeEnum">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Tipo de emisor de la factura.</xs:documentation>
                    <xs:documentation xml:lang="en">Type of invoice issuer.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Batch" type="BatchType">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Lote.</xs:documentation>
                    <xs:documentation xml:lang="en">Batch.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="BatchType">
        <xs:sequence>
            <xs:element name="BatchIdentifier" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Identificador único del lote de facturas.</xs:documentation>
                    <xs:documentation xml:lang="en">Unique identifier for the invoice batch.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoicesCount" type="xs:integer">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Número de facturas incluidas en el lote.</xs:documentation>
                    <xs:documentation xml:lang="en">Number of invoices included in the batch.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TotalInvoicesAmount" type="AmountContainerType">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Total facturas del lote.</xs:documentation>
                    <xs:documentation xml:lang="en">Total invoice amount for the batch.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TotalOutstandingAmount" type="AmountContainerType">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Total del lote a pago.</xs:documentation>
                    <xs:documentation xml:lang="en">Total outstanding amount for the batch.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TotalExecutableAmount" type="AmountContainerType">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Total del lote a Ejecutar.</xs:documentation>
                    <xs:documentation xml:lang="en">Total executable amount for the batch.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoiceCurrencyCode" type="CurrencyCodeType">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Moneda del lote, según la Norma ISO 4217. Valor por defecto: EUR.</xs:documentation>
                    <xs:documentation xml:lang="en">Currency of the batch, according to ISO 4217. Default value: EUR.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="AmountContainerType">
        <xs:sequence>
            <xs:element name="TotalAmount" type="xs:decimal">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Importe total expresado en la moneda de la factura.</xs:documentation>
                    <xs:documentation xml:lang="en">Total amount expressed in the invoice currency.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="EquivalentInEuros" type="xs:decimal" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Importe equivalente expresado en euros.</xs:documentation>
                    <xs:documentation xml:lang="en">Equivalent amount expressed in euros.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:simpleType name="CurrencyCodeType">
        <xs:restriction base="xs:string">
            <xs:length value="3"/>
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="CountryCodeType">
        <xs:restriction base="xs:string">
            <xs:length value="2"/>
        </xs:restriction>
    </xs:simpleType>

    <xs:complexType name="InvoiceWrapperType">
        <xs:sequence>
            <xs:element name="Parties" type="PartiesType">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Datos de las partes que intervienen en la factura.</xs:documentation>
                    <xs:documentation xml:lang="en">Data of the parties involved in the invoice.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Legislacion" type="LegislacionType" minOccurs="0"/>
            <xs:element name="Invoice" type="InvoiceType" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Datos del documento de factura.</xs:documentation>
                    <xs:documentation xml:lang="en">Invoice document data.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="PartiesType">
        <xs:sequence>
            <xs:element name="SellerParty" type="PartyType">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BG-4 | Grupo de términos de negocio que proporcionan información sobre el vendedor.</xs:documentation>
                    <xs:documentation xml:lang="en">BG-4 | Group of business terms providing information about the seller.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="BuyerParty" type="PartyType">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BG-7 | Un conjunto de términos de negocio que ofrecen información sobre el comprador.</xs:documentation>
                    <xs:documentation xml:lang="en">BG-7 | A set of business terms providing information about the buyer.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ThirdParty" type="PartyType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BG-ES-3 | Un conjunto de términos de negocio que ofrecen información relativa a un tercero.</xs:documentation>
                    <xs:documentation xml:lang="en">BG-ES-3 | A set of business terms providing information about a third party.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="PartyType">
        <xs:sequence>
            <xs:element name="TaxIdentification" type="TaxIdentificationType"/>
            <xs:element name="PartyIdentification" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-30 / BT-47 / Identificación adicional de la parte.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-30 / BT-47 / Additional identification of the party.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="LegalEntity" type="LegalEntityType">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Grupo de términos de negocio con la información jurídica y de contacto de la parte.</xs:documentation>
                    <xs:documentation xml:lang="en">Group of business terms with the legal and contact information of the party.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="TaxIdentificationType">
        <xs:sequence>
            <xs:element name="PersonTypeCode" type="PersonTypeCodeEnum">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Tipo de persona.</xs:documentation>
                    <xs:documentation xml:lang="en">Person type.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ResidenceTypeCode" type="ResidenceTypeCodeEnum">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Tipo de residencia a efectos fiscales.</xs:documentation>
                    <xs:documentation xml:lang="en">Type of residence for tax purposes.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TaxIdentificationNumber" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-32 / BT-48 / BT-ES-12 | Número de identificación fiscal (NIF/NIE) de la parte.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-32 / BT-48 / BT-ES-12 | Tax identification number (NIF/NIE) of the party.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="LegalEntityType">
        <xs:sequence>
            <xs:element name="CorporateName" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-27 / BT-44 | Nombre y apellidos o razón social de la parte.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-27 / BT-44 | Full name or company name of the party.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TradeName" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Nombre comercial de la parte.</xs:documentation>
                    <xs:documentation xml:lang="en">Trade name of the party.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="RegistrationData" type="RegistrationDataType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Datos registrales: Inscripcion Registro, Tomo, Folio...</xs:documentation>
                    <xs:documentation xml:lang="en">Registration data: Company Register entry, Volume, Folio...</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Address" type="AddressType">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BG-5 / BG-8 | Grupo de términos de negocio que proporciona información de la dirección postal de la parte.</xs:documentation>
                    <xs:documentation xml:lang="en">BG-5 / BG-8 | Group of business terms providing the postal address information of the party.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ContactDetails" type="ContactDetailsType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BG-6 / BG-9 | Grupo de términos de negocio que ofrecen información de contacto de la parte.</xs:documentation>
                    <xs:documentation xml:lang="en">BG-6 / BG-9 | Group of business terms providing contact information of the party.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="RegistrationDataType">
        <xs:sequence>
            <xs:element name="Book" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Libro de inscripción en el Registro Mercantil.</xs:documentation>
                    <xs:documentation xml:lang="en">Book of registration in the Commercial Register.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="RegisterOfCompaniesLocation" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Localidad del Registro Mercantil.</xs:documentation>
                    <xs:documentation xml:lang="en">Location of the Commercial Register.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Sheet" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Hoja de inscripción en el Registro Mercantil.</xs:documentation>
                    <xs:documentation xml:lang="en">Sheet of registration in the Commercial Register.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Folio" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Folio de inscripción en el Registro Mercantil.</xs:documentation>
                    <xs:documentation xml:lang="en">Folio of registration in the Commercial Register.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Section" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Sección de inscripción en el Registro Mercantil.</xs:documentation>
                    <xs:documentation xml:lang="en">Section of registration in the Commercial Register.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Volume" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Tomo de inscripción en el Registro Mercantil.</xs:documentation>
                    <xs:documentation xml:lang="en">Volume of registration in the Commercial Register.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="AdditionalRegistrationData" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Datos registrales adicionales.</xs:documentation>
                    <xs:documentation xml:lang="en">Additional registration data.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="AddressType">
        <xs:sequence>
            <xs:element name="Address" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-35 / BT-50 | Se consignará la dirección postal de la parte.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-35 / BT-50 | The postal address of the party.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="AdditionalAddress" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Información adicional de la dirección postal de la parte.</xs:documentation>
                    <xs:documentation xml:lang="en">Additional postal address information of the party.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="PostCode" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-38 / BT-53 | Se consignará el código postal de la parte.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-38 / BT-53 | The post code of the party.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Town" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-37 / BT-52 | Se consignará la localidad de la parte.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-37 / BT-52 | The city or town of the party.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Province" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-39 / BT-54 | Se consignará la provincia de la parte.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-39 / BT-54 | The province of the party.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="CountryCode" type="CountryCodeType">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-40 / BT-55 | Se consignará el código del país de la parte. En la Norma EN ISO 3166-1</xs:documentation>
                    <xs:documentation xml:lang="en">BT-40 / BT-55 | The country code of the party, according to the ISO 3166-1 standard.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="ContactDetailsType">
        <xs:sequence>
            <xs:element name="Telephone" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-42 / BT-57 | Número de teléfono de contacto de la parte.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-42 / BT-57 | Contact telephone number of the party.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Telephone2" type="xs:string" minOccurs="0"/>
            <xs:element name="WebAddress" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Dirección del sitio web de contacto.</xs:documentation>
                    <xs:documentation xml:lang="en">Website address of the contact.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ElectronicMail" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-43 / BT-58 | Dirección de correo electrónico de contacto de la parte.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-43 / BT-58 | Contact email address of the party.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="LastName" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Apellidos de la parte.</xs:documentation>
                    <xs:documentation xml:lang="en">Last name of the party.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="FirstName" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-41 / BT-56 | Nombre de la parte.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-41 / BT-56 | First name of the party.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="LegislacionType">
        <xs:sequence>
            <xs:any minOccurs="0" maxOccurs="unbounded" processContents="lax"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="InvoiceType">
        <xs:sequence>
            <xs:element name="InvoiceHeader" type="InvoiceHeaderType">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Grupo de términos de negocio con los datos de cabecera de la factura.</xs:documentation>
                    <xs:documentation xml:lang="en">Group of business terms with the invoice header data.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoiceIssueData" type="InvoiceIssueDataType">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Grupo de términos de negocio con los datos de expedición de la factura.</xs:documentation>
                    <xs:documentation xml:lang="en">Group of business terms with the invoice issuance data.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TaxesOutputs" type="TaxSectionType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BG-23 | Grupo de términos de negocio que proporcionan información sobre el desglose del IVA en diferentes categorías.</xs:documentation>
                    <xs:documentation xml:lang="en">BG-23 | Group of business terms providing information on the VAT breakdown by category.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TaxesWithheld" type="TaxSectionType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BG-ES-4 | Grupo de términos de negocio que proporcionan información relativa a las retenciones practicadas en la factura.</xs:documentation>
                    <xs:documentation xml:lang="en">BG-ES-4 | Group of business terms providing information on withholdings applied to the invoice.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoiceTotals" type="InvoiceTotalsType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BG-22 | Grupo de términos de negocio que proporcionan los totales monetarios de la factura.</xs:documentation>
                    <xs:documentation xml:lang="en">BG-22 | Group of business terms providing the monetary totals of the invoice.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Items" type="InvoiceLineListType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Datos de una línea individual de la factura.</xs:documentation>
                    <xs:documentation xml:lang="en">Data of an individual invoice line.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="PaymentDetails" type="PaymentDetailsType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BG-16 | Un grupo de términos de negocio que ofrecen información acerca del pago.</xs:documentation>
                    <xs:documentation xml:lang="en">BG-16 | A group of business terms providing information about payment.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="LegalLiterals" type="LegalLiteralsType" minOccurs="0"/>
            <xs:element name="AdditionalData" type="AdditionalDataType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Grupo de términos de negocio con datos adicionales de la factura.</xs:documentation>
                    <xs:documentation xml:lang="en">Group of business terms with additional invoice data.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="InvoiceHeaderType">
        <xs:sequence>
            <xs:element name="InvoiceNumber" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-1 | Número y serie que identifican la factura emitida.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-1 | Number and series identifying the issued invoice.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoiceDocumentType" type="InvoiceDocumentTypeEnum">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-3 | Tipo de factura.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-3 | Invoice type.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoiceClass" type="InvoiceClassEnum">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-ES-1 | Valor que indica la originalidad de la factura.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-ES-1 | Value indicating the originality of the invoice.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoiceDescription" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Descripción general del contenido de la factura.</xs:documentation>
                    <xs:documentation xml:lang="en">General description of the invoice content.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="PreviousInvoiceNumber" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Número de la factura anterior, cuando proceda.</xs:documentation>
                    <xs:documentation xml:lang="en">Number of the previous invoice, when applicable.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Corrective" type="CorrectiveType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BG-ES-1 | Este grupo recoge los datos relativos al tipo de factura rectificativa y/o modalidad.</xs:documentation>
                    <xs:documentation xml:lang="en">BG-ES-1 | This group contains data related to the type of corrective invoice and/or modality.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="CorrectiveType">
        <xs:sequence>
            <xs:element name="InvoiceNumber" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-25 | Número y serie que identifican la factura emitida referenciada o sustituida.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-25 | Number and series identifying the referenced or replaced issued invoice.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ReasonCode" type="ReasonCodeEnum">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-ES-2 | Indicador del motivo de la rectificación.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-ES-2 | Indicator of the reason for the correction.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ReasonDescription" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Descripción del motivo de la rectificación.</xs:documentation>
                    <xs:documentation xml:lang="en">Description of the reason for the correction.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InvoiceIssueDate" type="DateTimeType">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-26 | Fecha de expedición de la factura referenciada o sustituida.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-26 | Issue date of the referenced or replaced invoice.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="CorrectionMethod" type="CorrectionMethodEnum">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-ES-3 | Código que especifica la modalidad de rectificación empleada.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-ES-3 | Code specifying the correction modality used.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="CorrectionMethodDescription" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Descripción de la modalidad de rectificación empleada.</xs:documentation>
