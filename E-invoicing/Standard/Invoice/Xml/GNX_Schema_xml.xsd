                    <xs:documentation xml:lang="sp">BT-136 | Importe de la minoración, sin IVA.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-136 | The allowance amount, VAT excluded.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="LineChargesType">
        <xs:sequence>
            <xs:element name="Charge" type="LineChargeType" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="LineChargeType">
        <xs:sequence>
            <xs:element name="ChargeTypeCode" type="DiscountChargeTypeCodeEnum">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Código que identifica el tipo de cargo aplicado a la línea.</xs:documentation>
                    <xs:documentation xml:lang="en">Code identifying the type of charge applied to the line.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ChargeRate" type="xs:decimal" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Porcentaje aplicado para el cálculo del cargo de la línea.</xs:documentation>
                    <xs:documentation xml:lang="en">Percentage applied to calculate the line charge.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ChargeAmount" type="xs:decimal">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-141 | Importe del cargo, sin IVA.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-141 | The charge amount, VAT excluded.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="PaymentDetailsType">
        <xs:sequence>
            <xs:element name="Installment" type="InstallmentType" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="InstallmentType">
        <xs:sequence>
            <xs:element name="InstallmentDueDate" type="DateTimeType">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-9 | Fecha de vencimiento del pago.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-9 | Payment due date.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="InstallmentAmount" type="xs:decimal">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Importe correspondiente al vencimiento de pago.</xs:documentation>
                    <xs:documentation xml:lang="en">Amount corresponding to the payment instalment.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="PaymentMeans" type="PaymentMeansEnum">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-81 | Metodo de pago de la factura.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-81 | Payment method for the invoice.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Account" type="AccountType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BG-17 | Un grupo de términos de negocio utilizados para especificar pagos por transferencia.</xs:documentation>
                    <xs:documentation xml:lang="en">BG-17 | A group of business terms used to specify payments by credit transfer.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="CollectionAdditionalInformation" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Información adicional sobre el cobro.</xs:documentation>
                    <xs:documentation xml:lang="en">Additional information about the collection.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="PaymentReconciliationReference" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Referencia para la conciliación del pago.</xs:documentation>
                    <xs:documentation xml:lang="en">Reference for payment reconciliation.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="AccountType">
        <xs:sequence>
            <xs:element name="IBAN" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">BT-84 | Identificador único de la cuenta, se tratará de un código IBAN.</xs:documentation>
                    <xs:documentation xml:lang="en">BT-84 | Unique identifier of the account, treated as an IBAN code.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="AccountNumber" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Número de cuenta de pago.</xs:documentation>
                    <xs:documentation xml:lang="en">Payment account number.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="BankCode" type="xs:string">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Código de la entidad bancaria.</xs:documentation>
                    <xs:documentation xml:lang="en">Bank entity code.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="BIC" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="sp">Código de identificación bancaria (BIC/SWIFT) de la cuenta de pago.</xs:documentation>
                    <xs:documentation xml:lang="en">Bank identification code (BIC/SWIFT) of the payment account.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
