{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GNX Supplier Master Data",
  "description": "JSON schema for supplier master data using GENERIX standard structure.",
  "type": "object",
  "properties": {
    "supplierMasterData": {
      "type": "array",
      "description": "Supplier declaration",
      "minItems": 1,
      "maxItems": 999,
      "items": {
        "$ref": "#/definitions/SupplierMasterDataItem"
      }
    }
  },
  "required": ["supplierMasterData"],
  "additionalProperties": false,
  "definitions": {
    "SupplierMasterDataItem": {
      "type": "object",
      "description": "Supplier declaration record.",
      "additionalProperties": false,
      "properties": {
        "TRTEXC": {
          "type": "string",
          "description": "Movement processing code / 1 = Create, 2 = Modify or Create, 7 = Header modification, 9 = Cancellation",
          "enum": ["1", "2", "7", "9"],
          "default": "2"
        },
        "CODACT": {
          "type": "string",
          "description": "Logistics activity code",
          "minLength": 3,
          "maxLength": 3
        },
        "CODFOU": {
          "type": "string",
          "description": "Supplier code",
          "minLength": 1,
          "maxLength": 14
        },
        "TYPFOU": {
          "type": "string",
          "description": "Supplier type / 1 = Manufacturer, 2 = Wholesaler, 3 = Platform (transfers)",
          "enum": ["1", "2", "3"]
        },
        "NOMFOU": {
          "type": "string",
          "description": "Supplier name",
          "minLength": 1,
          "maxLength": 38
        },
        "AD1FOU": {
          "type": "string",
          "description": "Supplier address line 1",
          "minLength": 1,
          "maxLength": 38
        },
        "AD2FOU": {
          "type": "string",
          "description": "Supplier address line 2",
          "maxLength": 38
        },
        "AD3FOU": {
          "type": "string",
          "description": "Supplier address line 3",
          "maxLength": 38
        },
        "CPOFOU": {
          "type": "string",
          "description": "Supplier postal code in numeric format",
          "pattern": "^[0-9]{1,5}$"
        },
        "VILFOU": {
          "type": "string",
          "description": "Supplier city",
          "minLength": 1,
          "maxLength": 58
        },
        "PAYFOU": {
          "$ref": "#/definitions/CountryCode"
        },
        "TELFOU": {
          "type": "string",
          "description": "Supplier phone number",
          "maxLength": 20
        },
        "FAXFOU": {
          "type": "string",
          "description": "Supplier fax number",
          "maxLength": 20
        },
        "TLXFOU": {
          "type": "string",
          "description": "Supplier telex number",
          "maxLength": 15
        },
        "EDIFOU": {
          "type": "string",
          "description": "Supplier code for EDI",
          "maxLength": 14
        },
        "CODTRA": {
          "type": "string",
          "description": "Carrier code",
          "maxLength": 14
        },
        "IGLSIT": {
          "type": "string",
          "description": "Site identifier for Infolog GL",
          "pattern": "^[0-9]{1,3}$"
        },
        "CODTRE": {
          "type": "string",
          "description": "Receipt type code",
          "maxLength": 3
        },
        "GSTAVI": {
          "type": "string",
          "description": "Shipping notice management / 0 = no notice management, 1 = notices managed without disputes, 2 = notices managed with disputes",
          "enum": ["0", "1", "2"]
        },
        "GSTRCP": {
          "type": "string",
          "description": "Radio frequency receiving management type",
          "enum": ["0", "1", "2", "3"]
        },
        "TYPPRT": {
          "type": "string",
          "description": "Connector type (receiving)",
          "enum": ["1", "3"]
        },
        "CPIFOU": {
          "type": "string",
          "description": "Supplier postal code in alphanumeric format",
          "maxLength": 10
        },
        "EMBTIE": {
          "type": "boolean",
          "description": "Packaging allocation",
          "default": false
        },
        "FOUGMA": {
          "type": "string",
          "description": "Indicator for supplier management with GAMM@",
          "enum": ["0", "1", "2"]
        },
        "SYSMES": {
          "type": "boolean",
          "description": "Measurement system / false = Metric, true = Imperial",
          "default": false
        },
        "CODCLV": {
          "type": "string",
          "description": "Delivery requirement",
          "maxLength": 3
        },
        "GEEX1001": {
          "$ref": "#/definitions/SupplierAdditional01"
        },
        "GEEX1002": {
          "$ref": "#/definitions/SupplierAdditional02"
        }
      },
      "required": ["TRTEXC", "CODFOU", "NOMFOU", "AD1FOU", "VILFOU", "PAYFOU"]
    },
    "SupplierAdditional01": {
      "type": "object",
      "description": "Supplier Additional 01 declaration",
      "additionalProperties": false,
      "properties": {
        "RSPFOU": {
          "type": "string",
          "description": "Name of the person in charge at the supplier",
          "maxLength": 30
        },
        "EMLADR": {
          "type": "string",
          "description": "Email address",
          "minLength": 1,
          "maxLength": 50,
          "format": "email"
        },
        "CODCOG": {
          "type": "string",
          "description": "Geographic code",
          "maxLength": 15
        },
        "NUMACS": {
          "type": "string",
          "description": "Excise duty number (Alcohol)",
          "maxLength": 13
        },
        "AFFFAB": {
          "type": "boolean",
          "description": "Display MADE IN as batch",
          "default": false
        },
        "CODENL": {
          "type": "string",
          "description": "Collection code",
          "enum": ["0", "1"]
        },
        "CODFDC01": {
          "type": "string",
          "description": "Quality control sheet code 1",
          "maxLength": 3
        },
        "CODFDC02": {
          "type": "string",
          "description": "Quality control sheet code 2",
          "maxLength": 3
        },
        "CODGRP": {
          "type": "string",
          "description": "Grouping code",
          "enum": ["0", "1"]
        },
        "CODICM": {
          "type": "string",
          "description": "Incoterm code",
          "maxLength": 3
        },
        "CODTCT": {
          "type": "string",
          "description": "Control table code",
          "maxLength": 3
        },
        "CUMPRT": {
          "type": "string",
          "description": "Total number of picks (Detail and/or pallet)",
          "pattern": "^[0-9]{1,9}$"
        },
        "FOUGRP": {
          "type": "string",
          "description": "Generic group supplier",
          "maxLength": 14
        },
        "METREC": {
          "type": "string",
          "description": "Receipt validation method",
          "maxLength": 1
        },
        "NULRLQ": {
          "type": "boolean",
          "description": "Neutralization of remainder on receipt",
          "default": false
        },
        "PAYFAB": {
          "type": "string",
          "description": "Country of manufacture (MADE IN)",
          "maxLength": 20
        },
        "PEREMB": {
          "type": "string",
          "description": "Periodicity of packaging sales",
          "enum": ["0", "1", "2"]
        },
        "UNIFSR": {
          "type": "boolean",
          "description": "Uniqueness of serial numbers for the product",
          "default": false
        },
        "CODRGT": {
          "type": "string",
          "description": "Area code for transport",
          "maxLength": 3
        }
      }
    },
    "SupplierAdditional02": {
      "type": "object",
      "description": "Supplier Additional 02 declaration",
      "additionalProperties": false,
      "properties": {
        "CM1FOU": {
          "type": "string",
          "description": "Supplier comment (line 1)",
          "maxLength": 45
        },
        "CM2FOU": {
          "type": "string",
          "description": "Supplier comment (line 2)",
          "maxLength": 45
        },
        "CM3FOU": {
          "type": "string",
          "description": "Supplier comment (line 3)",
          "maxLength": 45
        },
        "LIBCPL": {
          "type": "string",
          "description": "Additional name",
          "maxLength": 38
        },
        "LIBCP2": {
          "type": "string",
          "description": "Additional name 2",
          "maxLength": 38
        }
      }
    },
